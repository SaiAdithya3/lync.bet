# PostgreSQL connection (matches docker-compose defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prediction_market

# Ethereum RPC (Sepolia)
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deployed PredictionMarket contract address (Sepolia)
PREDICTION_MARKET_ADDRESS=0x45e7911Af8c31bDeDf8A586BeEd8efEcACEb9c37

# Backend wallet private key (for fillOrder/createMarket - keep secret!)
BACKEND_PRIVATE_KEY=your_private_key_here

# Optional
PORT=3001
RUST_LOG=info
